# =============================================================================
# Anthropic Claude API (REQUIRED for AI Agent page)
# Get yours at: https://console.anthropic.com/
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# NYC Open Data / Socrata (OPTIONAL but RECOMMENDED for live data)
# Free tier supports anonymous queries (rate-limited to ~1000/hour).
# An app token raises that limit and ensures your queries aren't throttled.
# Get a token: https://data.cityofnewyork.us/profile/edit/developer_settings
# =============================================================================
SOCRATA_APP_TOKEN=

# =============================================================================
# Data mode:
#   - 'synthetic' : 100% locally generated, no internet required (default)
#   - 'real'      : Pulls live sales from NYC Department of Finance via
#                   NYC Open Data API (Socrata); tops up with synthetic
#                   if fewer rows than configured size, since hyperlocal
#                   features (walk score, school quality) are not in the
#                   government dataset.
# =============================================================================
DATA_MODE=synthetic

# =============================================================================
# OPTIONAL APIs (not used in default project; kept for future extension)
# =============================================================================
WALKSCORE_API_KEY=
CENSUS_API_KEY=
